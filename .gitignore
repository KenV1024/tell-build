.claude/settings.local.json
node_modules/
.DS_Store
Thumbs.db
__pycache__/
*.pyc

# 実運用データ(このリポジトリを日常使いする際に生成される実データ)
# パブリック公開版には含めない。ローカルでは通常どおり生成・利用される
/projects/*/
!/projects/.gitkeep
/state/*/
!/state/.gitkeep
/docs/specs/*/
!/docs/specs/.gitkeep
/reports/*
!/reports/.gitkeep
/tasks/todo.md
/tasks/lessons.md
